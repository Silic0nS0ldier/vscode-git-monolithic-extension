{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rangeStrategy": "bump",
  "customManagers": [
    {
      "description": "Bazel devcontainer feature",
      "customType": "regex",
      "depTypeTemplate": "devcontainer.feature.bazel",
      "managerFilePatterns": [
        ".devcontainer/feature-bazel/install.sh"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*(datasource=(?<datasource>.*?) )?depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s*.*?_VERSION=\"(?<currentValue>.*)\""
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "pnpm.catalog.vscode"
      ],
      "matchDepNames": [
        "@types/node"
      ],
      "enabled": false,
      "description": "@types/node needs to be kept in sync with VSCode minimum version."
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepNames": [
        "@eslint/js",
        "eslint",
        "typescript-eslint"
      ],
      "groupName": "eslint",
      "description": "Update ESLint packages together, since they release at the same time."
    },
    {
      "matchManagers": [
        "custom.regex",
        "npm"
      ],
      "matchDepNames": [
        "pnpm",
        "pnpm/pnpm"
      ],
      "groupName": "pnpm",
      "description": "Update all pnpm package manager references together."
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepNames": [
        "nodejs/node"
      ],
      "allowedVersions": "/^v\\d*[02468]\\./",
      "description": "Only update NodeJS to LTS (even major) versions."
    },
    {
      "matchManagers": [
        "custom.regex",
        "npm"
      ],
      "matchDepNames": [
        "nodejs/node",
        "@types/node"
      ],
      "excludeDepTypes": [
        "pnpm.catalog.vscode"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "nodejs",
      "description": "Update NodeJS and @types/node major versions together to keep them in sync."
    }
  ]
}
